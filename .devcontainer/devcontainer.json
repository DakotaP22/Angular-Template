{
	"name": "Angular 21",
	"dockerFile": "Dockerfile",
	"context": ".",
	"workspaceFolder": "/angular-21",
	"mounts": [
		"source=angular_node_modules,target=/angular-21/node_modules,type=volume",
		"source=${localWorkspaceFolder},target=/angular-21,type=bind"
	],
	"postCreateCommand": "npm install",
	"customizations": {
		"vscode": {
			"extensions": [
				"johnpapa.angular-essentials",
				"infinity1207.angular2-switcher",
				"formulahendry.auto-close-tag"
			]
		}
	}
}